{
  "commands": {
    "Node version": "node --version",
    "Start Rasa Inspector": {
      "id": "backend-guide",
      "cmd": "bash /home/codio/workspace/.guides/scripts/start_rasa_inspect.sh"
    }
  },
  "preview": {
    "Rasa Inspect": "https://{{domain5005}}/"
  },
  "environment": {
    "variables": {
      "RASA_LICENSE": "YOUR_RASA_LICENSE_KEY",
      "OPENAI_API_KEY": "YOUR_OPENAI_API_KEY"
    }
  }
}
